{
  "name": "fsc-pern",
  "private": true,
  "engines": {
    "node": "^20.18.0 || ^22.12.0 || ^24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "next build",
    "ports:kill": "kill-port 5173 3000 4000 || true",
    "port:kill:next": "kill-port 3000 || true",
    "dev:clean": "npm run ports:kill && npm run dev:all",
    "dev:next": "WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:next:clean": "npm run port:kill:next && npm run dev:next",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently -n API,NEXT,WEB -c yellow,cyan,green \"npm run dev:backend\" \"npm run dev:next\" \"npm run dev:frontend\"",
    "dev": "npm run dev:clean",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "db:push": "dotenv -e .env -e backend/.env -e .env.local -- prisma db push",
    "db:studio": "bash scripts/run-prisma-studio.sh"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-cloudinary": "^6.17.5",
    "nodemailer": "^8.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "kill-port": "^2.0.1",
    "postcss": "^8.5.8",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
