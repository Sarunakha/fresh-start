{
  "name": "@fsc/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:clean": "kill-port 4000 || true && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:seed": "dotenv -e .env -- prisma db seed",
    "prisma:studio": "bash ../scripts/run-prisma-studio.sh --backend"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^11.0.0",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "prisma": "^6.19.3",
    "kill-port": "^2.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^8.0.3"
  }
}
