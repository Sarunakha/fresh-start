generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: This file intentionally mirrors `../../prisma/schema.prisma` so the backend
// generates its Prisma client against the same schema in `backend/node_modules`.

enum BookingStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model PricingCategory {
  id        String        @id @default(cuid())
  key       String        @unique
  name      String
  sortOrder Int           @default(0)
  items     PricingItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingItem {
  id          String          @id @default(cuid())
  categoryId  String
  category    PricingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  key         String
  name        String
  description String?

  // Use text ranges exactly as your UI requires, e.g. "$100–$120", "$40–$55/hr", "$300–$500+"
  priceRange  String
  currency    String @default("AUD")
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, key])
}

model AddOn {
  id         String  @id @default(cuid())
  key        String  @unique
  name       String
  priceRange String
  currency   String  @default("AUD")
  active     Boolean @default(true)
  sortOrder  Int     @default(0)

  quoteRequests QuoteRequestAddOn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id                   String        @id @default(cuid())
  primaryContactName   String
  email                String        @default("")
  serviceSuburb        String
  serviceCategory      String
  preferredArrivalDate DateTime?
  notes                String?
  status               BookingStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Single admin user for protected admin dashboard.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Before/After portfolio entries managed in /admin/gallery.
model PortfolioEntry {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  beforeImage String
  afterImage  String
  matchScore  Int?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isFeatured])
}

/// Simple gallery entries for the public/admin gallery dashboard.
model GalleryEntry {
  id              String   @id @default(cuid())
  title           String
  description     String?
  category        String   // "RESIDENTIAL" | "COMMERCIAL"
  beforeImageUrl  String
  afterImageUrl   String
  matchPercentage Int?
  lastEdited      DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([category])
}

model BookingRequest {
  id                 String   @id @default(cuid())
  primaryContactName String
  serviceSuburb      String
  serviceCategory    String
  preferredDate      DateTime
  notes              String?  @db.Text
  status             String   @default("Pending Review")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Multi-step quote wizard submissions from the public site.
model QuoteRequest {
  id              String   @id @default(cuid())
  spaceType       String // e.g. "Commercial Office", "Residential"
  approximateSize String // e.g. "Under 1,000 sq ft"
  frequency       String // e.g. "Weekly", "One-time Deep Clean"
  contactName     String
  contactEmail    String
  contactPhone    String?
  status          String   @default("New Lead") // "New Lead", "Contacted", "Quoted"
  addOns          QuoteRequestAddOn[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuoteRequestAddOn {
  id            String       @id @default(cuid())
  quoteRequestId String
  addOnId       String
  quoteRequest  QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  addOn         AddOn        @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@unique([quoteRequestId, addOnId])
  @@index([addOnId])
  @@index([quoteRequestId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  type        String   @default("PACKAGE") // "PACKAGE" | "ADDON"
  description String?  @db.Text
  priceRange  String
  priceSort   Int      @default(0) // numeric sort key for ordering
  features    String[]
  isPopular   Boolean  @default(false)
  isVisible   Boolean  @default(true)
  showPrice   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isVisible])
}

model ClientReview {
  id         String   @id @default(cuid())
  clientName String
  role       String?
  reviewText String   @db.Text
  rating     Int      @default(5)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isVisible, createdAt])
}

/// Managed Cloudinary URLs for static sections on Home / About / Clients (Vite site).
model WebsiteAsset {
  id            String   @id @default(cuid())
  sectionKey    String   @unique
  cloudinaryUrl String
  altText       String   @default("Fresh Start Facility Solutions Sydney Image")
  updatedAt     DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default("hero-banner")
  headline  String
  subtext   String
  updatedAt DateTime @updatedAt
}

